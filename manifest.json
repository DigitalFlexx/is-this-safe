{
  "manifest_version": 3,
  "name": "Is This Safe? — Extension Auditor",
  "version": "0.1.0",
  "description": "See what your installed extensions can actually do. Plain-English risk scores. 100% local — nothing leaves your browser.",
  "permissions": ["management", "storage", "notifications"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Is This Safe?"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
